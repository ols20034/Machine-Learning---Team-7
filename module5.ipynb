
TEAM_NAME = "Team7"
IMAGE_SIZE = (100, 100)         # width, height in pixels
BATCH_SIZE = 64
EPOCHS = 20                     # increase to 25–30 if mini F1 is still low
FINE_TUNE_EPOCHS = 5            # extra pass with unfrozen backbone layers
LEARNING_RATE = 1e-3
SEED = 42

# Colab uses /content; change if running elsewhere
WORK_DIR = "/content"

# =============================================================================
# STEP 1 — DOWNLOAD & UNZIP DATA
# =============================================================================

import os
import shutil
import urllib.request
import zipfile
from pathlib import Path

BASE_URL = (
    "https://github.com/byui-cse/cse450-course/raw/master/data/roadsigns"
)
FILES = [
    "training1.zip",
    "training2.zip",
    "holdout.zip",
    "mini_holdout.zip",
    "mini_holdout_answers.csv",
]

work = Path(WORK_DIR)
work.mkdir(parents=True, exist_ok=True)
os.chdir(work)

for name in FILES:
    dest = work / name
    if not dest.exists():
        print(f"Downloading {name}...")
        urllib.request.urlretrieve(f"{BASE_URL}/{name}", dest)
    else:
        print(f"Already have {name}")

for zname in ("training1.zip", "training2.zip", "holdout.zip", "mini_holdout.zip"):
    zpath = work / zname
    if zpath.exists():
        with zipfile.ZipFile(zpath, "r") as zf:
            zf.extractall(work)

training_dir = work / "training"
if not training_dir.exists():
    training_dir.mkdir()
    for part in ("training1", "training2"):
        part_dir = work / part
        if part_dir.exists():
            for item in part_dir.iterdir():
                shutil.move(str(item), str(training_dir / item.name))

print("Data ready.")
print(f"  Training folders: {len(list(training_dir.iterdir()))} classes")
print(f"  Holdout images:   {len(list((work / 'holdout').glob('*')))}")
print(f"  Mini holdout:     {len(list((work / 'mini_holdout').glob('*')))}")

# =============================================================================
# STEP 2 — IMPORTS
# =============================================================================

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow import keras
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from tensorflow.keras.applications import MobileNetV2
from tensorflow.keras.layers import Dense, Dropout, GlobalAveragePooling2D
from tensorflow.keras import Model, callbacks
from sklearn.metrics import classification_report, confusion_matrix, f1_score

print("TensorFlow:", tf.__version__)
print("GPU available:", bool(tf.config.list_physical_devices("GPU")))

# =============================================================================
# STEP 3 — LOAD IMAGES (ImageDataGenerator)
# =============================================================================

TRAINING_DIR = str(training_dir) + "/"

train_datagen = ImageDataGenerator(
    rescale=1.0 / 255,
    validation_split=0.2,
    rotation_range=15,
    horizontal_flip=True,
    brightness_range=(0.8, 1.2),
)
val_datagen = ImageDataGenerator(rescale=1.0 / 255, validation_split=0.2)

train_generator = train_datagen.flow_from_directory(
    TRAINING_DIR,
    target_size=IMAGE_SIZE,
    batch_size=BATCH_SIZE,
    class_mode="sparse",
    subset="training",
    seed=SEED,
    shuffle=True,
)
val_generator = val_datagen.flow_from_directory(
    TRAINING_DIR,
    target_size=IMAGE_SIZE,
    batch_size=BATCH_SIZE,
    class_mode="sparse",
    subset="validation",
    seed=SEED,
    shuffle=False,
)

NUM_CLASSES = train_generator.num_classes
print(f"Number of classes: {NUM_CLASSES}")
print("Folder → label index (first 5):", list(train_generator.class_indices.items())[:5])

# =============================================================================
# STEP 4 — PEEK AT SAMPLE IMAGES (sanity check before training)
# =============================================================================

images, labels = next(train_generator)
plt.figure(figsize=(10, 10))
for i in range(min(9, len(images))):
    ax = plt.subplot(3, 3, i + 1)
    plt.imshow(images[i])
    plt.title(f"class {int(labels[i])}")
    plt.axis("off")
plt.suptitle("Sample training batch — do these look like road signs?")
plt.show()

# =============================================================================
# STEP 5 — BUILD MODEL (Transfer Learning)
#
# =============================================================================

backbone = MobileNetV2(
    include_top=False,
    weights="imagenet",
    input_shape=(*IMAGE_SIZE, 3),
)
backbone.trainable = False  # freeze pretrained layers for first training pass

inputs = keras.Input(shape=(*IMAGE_SIZE, 3))
x = backbone(inputs, training=False)
x = GlobalAveragePooling2D()(x)
x = Dropout(0.3)(x)
outputs = Dense(NUM_CLASSES, activation="softmax")(x)
model = Model(inputs, outputs, name="signs_classifier")

model.compile(
    optimizer=keras.optimizers.Adam(learning_rate=LEARNING_RATE),
    loss="sparse_categorical_crossentropy",
    metrics=["accuracy"],
)
model.summary()

# =============================================================================
# STEP 6 — TRAIN
#
# =============================================================================

print("\n--- Phase 1: train classifier head (backbone frozen) ---")
history = model.fit(
    train_generator,
    validation_data=val_generator,
    epochs=EPOCHS,
    callbacks=[
        callbacks.EarlyStopping(
            monitor="val_loss", patience=6, restore_best_weights=True
        ),
        callbacks.ReduceLROnPlateau(
            monitor="val_loss", factor=0.5, patience=3, min_lr=1e-6
        ),
    ],
)

plt.figure(figsize=(10, 4))
plt.subplot(1, 2, 1)
plt.plot(history.history["accuracy"], label="train")
plt.plot(history.history["val_accuracy"], label="val")
plt.title("Accuracy")
plt.legend()
plt.subplot(1, 2, 2)
plt.plot(history.history["loss"], label="train")
plt.plot(history.history["val_loss"], label="val")
plt.title("Loss")
plt.legend()
plt.tight_layout()
plt.show()

# =============================================================================
# STEP 7 — FINE-TUNE
#
# =============================================================================

if FINE_TUNE_EPOCHS > 0:
    print("\n--- Phase 2: fine-tune last MobileNet blocks ---")
    backbone.trainable = True
    for layer in backbone.layers[:-30]:
        layer.trainable = False
    model.compile(
        optimizer=keras.optimizers.Adam(learning_rate=1e-4),
        loss="sparse_categorical_crossentropy",
        metrics=["accuracy"],
    )
    history_ft = model.fit(
        train_generator,
        validation_data=val_generator,
        epochs=FINE_TUNE_EPOCHS,
        callbacks=[
            callbacks.EarlyStopping(
                monitor="val_loss", patience=3, restore_best_weights=True
            ),
        ],
    )

# =============================================================================
# STEP 8 — MINI HOLDOUT
#
# Grading band uses MACRO F1 (not accuracy alone):
#   macro F1 >= 0.91 → 100%
#   macro F1 <= 0.79 → 0%
#   between          → scaled linearly
# =============================================================================

def recommended_grade(macro_f1: float) -> float:
    top, bottom = 0.91, 0.79
    if macro_f1 >= top:
        return 100.0
    if macro_f1 <= bottom:
        return 0.0
    return (macro_f1 - bottom) / (top - bottom) * 100.0


test_datagen = ImageDataGenerator(rescale=1.0 / 255)

mini_generator = test_datagen.flow_from_directory(
    str(work),
    classes=["mini_holdout"],
    target_size=IMAGE_SIZE,
    class_mode=None,
    shuffle=False,
    batch_size=BATCH_SIZE,
)

mini_probs = model.predict(mini_generator, verbose=1)
mini_preds = np.argmax(mini_probs, axis=1)

answers = pd.read_csv(work / "mini_holdout_answers.csv")
targets = answers["ClassId"].to_numpy()

mini_acc = (mini_preds == targets).mean()
mini_f1 = f1_score(targets, mini_preds, average="macro")
mini_grade = recommended_grade(mini_f1)

print("\n=== MINI HOLDOUT RESULTS (check this before submitting!) ===")
print(f"Accuracy:  {mini_acc:.4f}")
print(f"Macro F1:  {mini_f1:.4f}")
print(f"Est. holdout grade component: {mini_grade:.1f}%")
print("\n" + classification_report(targets, mini_preds))

# Confusion matrix on mini holdout (which signs get confused?)
cm = confusion_matrix(targets, mini_preds)
plt.figure(figsize=(12, 10))
plt.imshow(cm, cmap="Blues")
plt.title("Confusion matrix (mini holdout) — bright off-diagonal = mix-ups")
plt.xlabel("Predicted class")
plt.ylabel("True class")
plt.colorbar()
plt.show()

# Safety-critical signs: STOP=14, Yield=13 (folder index = class id)
for critical_id, name in [(14, "STOP"), (13, "Yield")]:
    mask = targets == critical_id
    if mask.any():
        recall = (mini_preds[mask] == critical_id).mean()
        print(f"Recall for {name} (class {critical_id}): {recall:.2%}")

# =============================================================================
# STEP 9 — FULL HOLDOUT PREDICTIONS
# =============================================================================

holdout_generator = test_datagen.flow_from_directory(
    str(work),
    classes=["holdout"],
    target_size=IMAGE_SIZE,
    class_mode=None,
    shuffle=False,
    batch_size=BATCH_SIZE,
)

holdout_probs = model.predict(holdout_generator, verbose=1)
holdout_preds = np.argmax(holdout_probs, axis=1)

csv_name = f"{TEAM_NAME}-module5-predictions.csv"
pd.DataFrame({"predictions": holdout_preds.astype(int)}).to_csv(csv_name, index=False)
model.save("signs_model.keras")
